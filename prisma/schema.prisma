generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PersonType {
  INTERNAL
  EXTERNAL
}

enum StatusCode {
  Of
  Tb
  DCH
  DMH
  DS
  DV
  DET
  V
  Li
  Cs
}

model Person {
  id        String     @id @default(cuid())
  name      String
  type      PersonType @default(INTERNAL)
  email     String?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  schedules Schedule[]

  @@index([active])
}

model Schedule {
  id       String     @id @default(cuid())
  personId String
  person   Person     @relation(fields: [personId], references: [id])
  date     DateTime   @db.Date
  status   StatusCode

  @@unique([personId, date])
  @@index([date])
}

model Config {
  id       String @id @default("main")
  maxSeats Int    @default(30)
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  personId  String?
  createdAt DateTime @default(now())
}
